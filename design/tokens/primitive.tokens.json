{
  "color": {
    "$type": "color",
    "$description": "Primitive color palette based on Edo traditional colors",
    "primitive": {
      "ai": {
        "$description": "Ai-iro (indigo blue) - Japan Blue",
        "50": { "$value": "#e8f4f8" },
        "100": { "$value": "#c5dfe8" },
        "200": { "$value": "#9dc5d6" },
        "300": { "$value": "#6fa8c1" },
        "400": { "$value": "#4790ac" },
        "500": { "$value": "#165e83" },
        "600": { "$value": "#124e6d" },
        "700": { "$value": "#0e3e57" },
        "800": { "$value": "#0a2e41" },
        "900": { "$value": "#0f2350" }
      },
      "kurenai": {
        "$description": "Kurenai (crimson red)",
        "50": { "$value": "#fce8ed" },
        "100": { "$value": "#f5b8c7" },
        "500": { "$value": "#d7003a" },
        "700": { "$value": "#b7282e" },
        "900": { "$value": "#8b0020" }
      },
      "shu": {
        "$description": "Shu-iro (vermillion)",
        "500": { "$value": "#eb6101" }
      },
      "yamabuki": {
        "$description": "Yamabuki-iro (bright yellow)",
        "500": { "$value": "#f8b500" }
      },
      "moegi": {
        "$description": "Moegi (yellow-green)",
        "500": { "$value": "#aacf53" }
      },
      "tokiwa": {
        "$description": "Tokiwa-iro (evergreen)",
        "500": { "$value": "#007b43" }
      },
      "kogane": {
        "$description": "Kogane (gold)",
        "500": { "$value": "#e6b422" }
      },
      "neutral": {
        "$description": "Neutral tones",
        "gofun": { "$value": "#fffffc", "$description": "Gofun-iro (shell white)" },
        "kinari": { "$value": "#fbfaf5", "$description": "Kinari-iro (natural white)" },
        "shironeri": { "$value": "#f3f3f3", "$description": "Shironeri (off-white)" },
        "nezumi": { "$value": "#949495", "$description": "Nezumi-iro (mouse grey)" },
        "gin-nezu": { "$value": "#afafb0", "$description": "Gin-nezu (silver grey)" },
        "sumi": { "$value": "#595857", "$description": "Sumi (charcoal)" },
        "shikkoku": { "$value": "#0d0015", "$description": "Shikkoku (jet black)" }
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "$description": "Spacing scale",
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.25rem" },
    "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" },
    "10": { "$value": "2.5rem" },
    "12": { "$value": "3rem" },
    "16": { "$value": "4rem" }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "body": { "$value": ["Noto Sans JP", "Hiragino Kaku Gothic ProN", "sans-serif"] },
      "heading": { "$value": ["Shippori Mincho", "Noto Serif JP", "serif"] },
      "display": { "$value": ["Zen Antique", "Shippori Mincho", "serif"] },
      "mono": { "$value": ["Noto Sans Mono", "monospace"] }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "0.64rem" },
      "sm": { "$value": "0.8rem" },
      "md": { "$value": "1rem" },
      "lg": { "$value": "1.25rem" },
      "xl": { "$value": "1.563rem" },
      "2xl": { "$value": "1.953rem" },
      "3xl": { "$value": "2.441rem" },
      "4xl": { "$value": "3.052rem" }
    },
    "weight": {
      "$type": "fontWeight",
      "light": { "$value": 300 },
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "bold": { "$value": 700 }
    },
    "line-height": {
      "$type": "number",
      "tight": { "$value": 1.25 },
      "normal": { "$value": 1.6 },
      "relaxed": { "$value": 1.8 }
    }
  },
  "border-radius": {
    "$type": "dimension",
    "sm": { "$value": "0.25rem" },
    "md": { "$value": "0.5rem" },
    "lg": { "$value": "0.75rem" },
    "xl": { "$value": "1rem" },
    "full": { "$value": "9999px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px",
        "color": "#0d001508"
      }
    },
    "md": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "6px",
        "spread": "0px",
        "color": "#0d001512"
      }
    },
    "lg": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "10px",
        "blur": "15px",
        "spread": "0px",
        "color": "#0d00151a"
      }
    },
    "xl": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "20px",
        "blur": "25px",
        "spread": "0px",
        "color": "#0d00151f"
      }
    }
  },
  "duration": {
    "$type": "duration",
    "fast": { "$value": "150ms" },
    "normal": { "$value": "250ms" },
    "slow": { "$value": "400ms" }
  },
  "easing": {
    "$type": "cubicBezier",
    "default": { "$value": [0.4, 0, 0.2, 1] },
    "in": { "$value": [0.4, 0, 1, 1] },
    "out": { "$value": [0, 0, 0.2, 1] }
  }
}
