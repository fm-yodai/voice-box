{
  "name": "voice-box",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "目安箱 - Anonymous voice box for organizations",
  "scripts": {
    "dev:frontend": "pnpm --filter @voice-box/frontend dev",
    "dev:backend": "pnpm --filter @voice-box/backend dev",
    "build": "pnpm -r build",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:coverage": "pnpm -r test:coverage",
    "tokens:build": "pnpm --filter @voice-box/frontend tokens:build",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.11.1",
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "typescript": "^5.9.3"
  }
}
