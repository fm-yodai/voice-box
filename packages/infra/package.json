{
  "name": "@voice-box/infra",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm --filter @voice-box/shared build",
    "test": "vitest run",
    "test:watch": "vitest",
    "cdk": "cdk",
    "cdk:synth": "cdk synth",
    "cdk:diff": "cdk diff",
    "cdk:deploy": "cdk deploy",
    "clean": "rm -rf dist cdk.out"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.200.0",
    "constructs": "^10.4.2"
  },
  "devDependencies": {
    "aws-cdk": "^2.200.0",
    "@types/node": "^25.2.1",
    "esbuild": "^0.25.0",
    "vitest": "^4.0.18"
  }
}
